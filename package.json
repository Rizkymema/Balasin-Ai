    "eslint": "^9.30.1",
    "eslint-config-next": "^15.3.5",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
