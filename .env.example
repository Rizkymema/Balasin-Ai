NEXT_PUBLIC_APP_NAME=Balesin Desk
NEXT_PUBLIC_APP_URL=https://balasin-ai-tau.vercel.app

# Dashboard auth and worker security
SESSION_COOKIE_NAME=balesin_session
SESSION_SECRET=change-this-session-secret
WORKER_SECRET=change-this-worker-secret
ALLOW_DEMO_LOGIN=false
DEMO_LOGIN_PASSWORD=
AUTH_ALLOWED_EMAILS=
AUTH_ALLOWED_DOMAINS=
NEXT_PUBLIC_ALLOW_DEMO_REGISTER=false

# Google login
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Supabase (optional, required only if using Supabase persistence/auth helpers)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local storage / Vercel Blob
BALESIN_STORAGE_DIR=
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
BLOB_ACCESS_MODE=private

# Public webhook / external fetch hardening
WEBCHAT_WEBHOOK_SECRET=
EXTERNAL_FETCH_ALLOWED_HOSTS=

# Meta / WhatsApp
WHATSAPP_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_WHATSAPP_APP_ID=
META_APP_SECRET=
WHATSAPP_APP_SECRET=
NEXT_PUBLIC_META_WA_CONFIG_ID=

# Meta / Instagram
META_APP_ID=
INSTAGRAM_APP_ID=
NEXT_PUBLIC_INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
NEXT_PUBLIC_META_IG_CONFIG_ID=

# Do not copy VERCEL_*, TURBO_*, or NX_* variables from `vercel env pull`
# into your working env files. Those are runtime/build metadata, not app config.
